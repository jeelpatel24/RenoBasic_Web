rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Project photos — authenticated users can read, homeowners can write their own
    match /projects/{projectId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile pictures — users can read/write their own
    match /profiles/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024   // Max 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
